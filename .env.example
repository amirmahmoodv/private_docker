# Copy to .env for local use, or set these as Environment Variables in RunFlare.

# A long random string. Keep it STABLE so in-progress uploads survive restarts.
REGISTRY_HTTP_SECRET=change-me-to-a-long-random-string

# --- Access control (enforced by Caddy) ---

# Space-separated hostnames the registry will answer on.
# e.g. "myreg.apps.runflare.com registry.example.com"
ALLOWED_HOSTS=localhost

# Space-separated client IPs / CIDR ranges allowed to connect.
# e.g. "203.0.113.5 198.51.100.0/24 2001:db8::/32"
# To allow everyone: "0.0.0.0/0 ::/0"
ALLOWED_IPS=0.0.0.0/0 ::/0
